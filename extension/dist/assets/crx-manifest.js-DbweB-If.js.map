export default "{\"manifest_version\":3,\"name\":\"EcoThread — Sustainable Fashion Scanner\",\"short_name\":\"EcoThread\",\"version\":\"0.1.0\",\"description\":\"Check sustainability scores on any shopping site. See where your clothes are made, what they're made of, and their carbon footprint.\",\"action\":{\"default_popup\":\"src/popup/index.html\",\"default_title\":\"EcoThread — Sustainability Scanner\"},\"background\":{\"service_worker\":\"src/background/service-worker.ts\",\"type\":\"module\"},\"content_scripts\":[{\"matches\":[\"https://*.depop.com/*\",\"https://*.vinted.com/*\",\"https://*.vinted.co.uk/*\",\"https://*.vinted.fr/*\",\"https://*.vinted.de/*\",\"https://*.vinted.it/*\",\"https://*.vinted.es/*\",\"https://*.vinted.nl/*\",\"https://*.vinted.pl/*\",\"https://*.ebay.com/*\",\"https://*.thredup.com/*\",\"https://*.vestiairecollective.com/*\",\"https://*.whatnot.com/*\",\"https://*.zara.com/*\",\"https://*.hm.com/*\",\"https://*.shein.com/*\",\"https://*.asos.com/*\",\"https://*.urbanoutfitters.com/*\",\"https://*.nordstrom.com/*\",\"https://*.revolve.com/*\",\"https://*.amazon.com/*\",\"https://*.shopify.com/*\",\"https://*.macys.com/*\",\"https://*.barbour.com/*\",\"https://*.quince.com/*\",\"https://*.ae.com/*\"],\"js\":[\"src/content/content-script.ts\"],\"run_at\":\"document_idle\"}],\"permissions\":[\"activeTab\",\"storage\",\"scripting\"],\"host_permissions\":[\"https://*/*\"]}"